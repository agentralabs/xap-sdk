{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xap.agentralabs.tech/schemas/v0.2/settlement-intent.json",
  "title": "SettlementIntent",
  "description": "XAP v0.2 — The escrow instruction. Funds lock, conditions verify, funds release or refund. The core primitive. Every field, every constraint, every failure mode defined with zero ambiguity.",
  "type": "object",
  "required": [
    "settlement_id",
    "negotiation_id",
    "state",
    "payer_agent",
    "payee_agents",
    "total_amount_minor_units",
    "currency",
    "adapter",
    "conditions",
    "timeout_seconds",
    "on_timeout",
    "on_partial_completion",
    "on_failure",
    "chargeback_policy",
    "idempotency_key",
    "finality_class",
    "xap_version",
    "created_at",
    "signature"
  ],
  "properties": {
    "settlement_id": {
      "type": "string",
      "pattern": "^stl_[a-f0-9]{8}$",
      "description": "Unique settlement identifier."
    },
    "negotiation_id": {
      "type": "string",
      "pattern": "^neg_[a-f0-9]{8}$",
      "description": "Reference to the accepted NegotiationContract."
    },
    "state": {
      "type": "string",
      "enum": [
        "PENDING_LOCK",
        "FUNDS_LOCKED",
        "EXECUTING",
        "PENDING_VERIFICATION",
        "PENDING_RELEASE",
        "SETTLED",
        "REFUNDED",
        "PARTIAL",
        "TIMEOUT",
        "FAILED_LOCK",
        "RELEASE_FAILED",
        "DISPUTED"
      ],
      "description": "Current settlement state. Every state has defined transitions. No money ever in limbo."
    },
    "payer_agent": {
      "type": "string",
      "pattern": "^agent_[a-f0-9]{8}$",
      "description": "Agent locking funds into escrow."
    },
    "payee_agents": {
      "type": "array",
      "minItems": 1,
      "description": "Agents receiving payment. share_bps must sum to exactly 10000.",
      "items": {
        "$ref": "#/$defs/PayeeAgent"
      }
    },
    "total_amount_minor_units": {
      "type": "integer",
      "minimum": 1,
      "description": "Total amount in minor currency units. No floats. Ever."
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3,6}$",
      "description": "ISO 4217 currency code or crypto symbol (e.g., USD, USDC)."
    },
    "adapter": {
      "type": "string",
      "enum": ["stripe", "usdc_base", "usdc_ethereum", "test"],
      "description": "Which settlement rail to use."
    },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "description": "What must be true for funds to release.",
      "items": {
        "$ref": "#/$defs/Condition"
      }
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400,
      "description": "Maximum execution + verification time. Max 24 hours."
    },
    "on_timeout": {
      "type": "string",
      "enum": ["full_refund", "pro_rata", "hold_for_dispute"],
      "description": "What happens when timeout hits."
    },
    "on_partial_completion": {
      "type": "string",
      "enum": ["pro_rata", "full_refund", "redistribute", "hold_for_dispute"],
      "description": "What happens on partial success."
    },
    "on_failure": {
      "type": "string",
      "enum": ["full_refund", "hold_for_dispute"],
      "description": "What happens on complete failure."
    },
    "chargeback_policy": {
      "type": "string",
      "enum": ["proportional", "payer_absorbs", "orchestrator_absorbs", "platform_absorbs"],
      "description": "Who absorbs chargeback loss on split settlements."
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^idem_[a-f0-9]{8,32}$",
      "description": "For safe retries. Same key always returns same result."
    },
    "finality_class": {
      "type": "string",
      "enum": ["instant", "reversible", "confirmation_required"],
      "description": "When is this settlement truly final."
    },
    "reversal_window_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "How long the settlement can be reversed after completion. 0 = irreversible."
    },
    "org_id": {
      "type": "string",
      "pattern": "^org_[a-f0-9]{8}$",
      "description": "Organizational context for budget enforcement."
    },
    "xap_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Protocol version (semver)."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the intent was created."
    },
    "signature": {
      "type": "string",
      "description": "Ed25519 signature by payer_agent."
    },
    "execution_result": {
      "type": "object",
      "description": "Populated by the executing agent upon task completion.",
      "properties": {
        "submitted_by": { "type": "string" },
        "submitted_at": { "type": "string", "format": "date-time" },
        "output": { "type": "object" },
        "quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "latency_ms": { "type": "integer", "minimum": 0 },
        "completion_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
        "execution_signature": { "type": "string" }
      }
    },
    "verification_result": {
      "type": "object",
      "description": "Populated after condition verification.",
      "properties": {
        "verified_at": { "type": "string", "format": "date-time" },
        "conditions_evaluated": { "type": "array" },
        "all_required_met": { "type": "boolean" },
        "weighted_score_bps": { "type": "integer" },
        "resulting_state": { "type": "string" },
        "verification_detail": { "type": "string" }
      }
    },
    "settled_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of final state resolution."
    },
    "split_distributions": {
      "type": "array",
      "description": "Actual amounts distributed to each payee.",
      "items": { "type": "object" }
    },
    "execution_receipt_id": {
      "type": "string",
      "description": "ID of the ExecutionReceipt created on settlement."
    }
  },
  "$defs": {
    "PayeeAgent": {
      "type": "object",
      "description": "A payee in the split settlement.",
      "required": ["agent_id", "share_bps", "role"],
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^agent_[a-f0-9]{8}$",
          "description": "Payee agent identifier."
        },
        "share_bps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "This agent's share in basis points. All share_bps must sum to exactly 10000."
        },
        "role": {
          "type": "string",
          "enum": ["primary_executor", "sub_executor", "data_provider", "tool_provider", "orchestrator", "verifier", "platform"],
          "description": "Agent's role in the workflow."
        },
        "min_payout_minor_units": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum payout threshold. Below this, accumulate as credit."
        }
      },
      "additionalProperties": false
    },
    "Condition": {
      "type": "object",
      "description": "A verification condition for settlement.",
      "required": ["condition_id", "type", "check", "verifier", "required"],
      "properties": {
        "condition_id": {
          "type": "string",
          "pattern": "^cond_[a-f0-9]{4}$",
          "description": "Unique within this settlement."
        },
        "type": {
          "type": "string",
          "enum": ["deterministic", "probabilistic", "human_approval"],
          "description": "Verification type."
        },
        "check": {
          "type": "string",
          "description": "What is being verified."
        },
        "operator": {
          "type": "string",
          "enum": ["eq", "gte", "lte", "gt", "lt"],
          "description": "Comparison operator. Required for probabilistic."
        },
        "threshold": {
          "type": "integer",
          "description": "Threshold value. Required for probabilistic."
        },
        "verifier": {
          "type": "string",
          "enum": ["engine", "payer", "payee", "neutral_third_party"],
          "description": "Who runs the verification."
        },
        "verifier_agent_id": {
          "type": "string",
          "pattern": "^agent_[a-f0-9]{8}$",
          "description": "Required when verifier is neutral_third_party."
        },
        "weight_bps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "description": "How much this condition affects outcome for weighted multi-condition."
        },
        "required": {
          "type": "boolean",
          "description": "Must this condition pass for settlement?"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "description": "Per-condition timeout override."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "probabilistic" } },
            "required": ["type"]
          },
          "then": {
            "required": ["operator", "threshold"]
          }
        },
        {
          "if": {
            "properties": { "verifier": { "const": "neutral_third_party" } },
            "required": ["verifier"]
          },
          "then": {
            "required": ["verifier_agent_id"]
          }
        }
      ]
    }
  }
}
