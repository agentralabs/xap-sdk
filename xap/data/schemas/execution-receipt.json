{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xap.agentralabs.tech/schemas/v0.2/execution-receipt.json",
  "title": "ExecutionReceipt",
  "description": "XAP v0.2 — The permanent, tamper-proof, cryptographically signed record of a completed settlement. Issued once per terminal SettlementIntent. Hash-chained per agent. Never amended.",
  "type": "object",
  "required": [
    "receipt_id",
    "settlement_id",
    "negotiation_id",
    "payer_agent",
    "outcome",
    "conditions_results",
    "payouts",
    "execution_metrics",
    "reputation_impacts",
    "verity_hash",
    "chain_position",
    "adapter_used",
    "finality_status",
    "xap_version",
    "issued_at",
    "signatures"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^rcpt_[a-f0-9]{8}$",
      "description": "Unique receipt identifier."
    },
    "settlement_id": {
      "type": "string",
      "pattern": "^stl_[a-f0-9]{8}$",
      "description": "The SettlementIntent this receipt records."
    },
    "negotiation_id": {
      "type": "string",
      "pattern": "^neg_[a-f0-9]{8}$",
      "description": "The NegotiationContract this settlement executed."
    },
    "payer_agent": {
      "type": "string",
      "pattern": "^agent_[a-f0-9]{8}$",
      "description": "Agent who paid."
    },
    "outcome": {
      "type": "string",
      "enum": ["SETTLED", "REFUNDED", "PARTIAL", "TIMEOUT", "DISPUTED", "FAILED_LOCK", "RELEASE_FAILED"],
      "description": "Final outcome of the settlement."
    },
    "conditions_results": {
      "type": "array",
      "minItems": 1,
      "description": "What each condition produced.",
      "items": { "$ref": "#/$defs/ConditionResult" }
    },
    "payouts": {
      "type": "array",
      "description": "What each payee actually received.",
      "items": { "$ref": "#/$defs/Payout" }
    },
    "refunds": {
      "type": "array",
      "description": "Any amounts returned to payer.",
      "items": { "$ref": "#/$defs/Refund" }
    },
    "execution_metrics": {
      "$ref": "#/$defs/ExecutionMetrics"
    },
    "reputation_impacts": {
      "type": "array",
      "description": "How this settlement affects each agent's reputation.",
      "items": { "$ref": "#/$defs/ReputationImpact" }
    },
    "verity_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Link to the VerityReceipt for decision replay."
    },
    "chain_previous_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Hash of the previous receipt in this agent's receipt chain."
    },
    "chain_position": {
      "type": "integer",
      "minimum": 1,
      "description": "This receipt's position in the agent's receipt chain."
    },
    "adapter_used": {
      "type": "string",
      "enum": ["stripe", "usdc_base", "usdc_ethereum", "test"],
      "description": "Which settlement adapter processed this."
    },
    "adapter_reference": {
      "type": "string",
      "description": "Adapter-specific transaction ID (Stripe charge ID, on-chain tx hash)."
    },
    "finality_status": {
      "type": "string",
      "enum": ["final", "pending_confirmation", "within_reversal_window", "reversed"],
      "description": "Current finality state."
    },
    "reversal_window_ends_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the reversal window closes."
    },
    "org_id": {
      "type": "string",
      "pattern": "^org_[a-f0-9]{8}$",
      "description": "Organizational context."
    },
    "xap_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Protocol version (semver)."
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this receipt was issued."
    },
    "signatures": {
      "$ref": "#/$defs/Signatures"
    }
  },
  "$defs": {
    "ConditionResult": {
      "type": "object",
      "required": ["condition_id", "type", "check", "passed", "verified_by", "verified_at"],
      "properties": {
        "condition_id": {
          "type": "string",
          "pattern": "^cond_[a-f0-9]{4}$"
        },
        "type": {
          "type": "string",
          "enum": ["deterministic", "probabilistic", "human_approval"]
        },
        "check": { "type": "string" },
        "passed": { "type": "boolean" },
        "actual_value": { "type": "integer" },
        "threshold": { "type": "integer" },
        "operator": {
          "type": "string",
          "enum": ["eq", "gte", "lte", "gt", "lt"]
        },
        "verified_by": {
          "type": "string",
          "enum": ["engine", "payer", "payee", "neutral_third_party"]
        },
        "verified_by_agent_id": {
          "type": "string",
          "pattern": "^agent_[a-f0-9]{8}$"
        },
        "verified_at": {
          "type": "string",
          "format": "date-time"
        },
        "confidence_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "evidence_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "Payout": {
      "type": "object",
      "required": ["agent_id", "role", "declared_share_bps", "base_amount_minor_units", "final_amount_minor_units", "currency", "status"],
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^agent_[a-f0-9]{8}$"
        },
        "role": {
          "type": "string",
          "enum": ["primary_executor", "sub_executor", "data_provider", "tool_provider", "orchestrator", "verifier", "platform"]
        },
        "declared_share_bps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "base_amount_minor_units": {
          "type": "integer",
          "minimum": 0
        },
        "modifier_applied_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "final_amount_minor_units": {
          "type": "integer",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3,6}$"
        },
        "status": {
          "type": "string",
          "enum": ["paid", "credited", "failed", "refunded"]
        },
        "adapter_reference": { "type": "string" },
        "credited_reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Refund": {
      "type": "object",
      "required": ["agent_id", "amount_minor_units", "currency", "reason"],
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^agent_[a-f0-9]{8}$"
        },
        "amount_minor_units": {
          "type": "integer",
          "minimum": 1
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3,6}$"
        },
        "reason": {
          "type": "string",
          "enum": ["full_refund", "partial_failure", "timeout", "condition_failed", "split_remainder", "chargeback_recovery"]
        },
        "adapter_reference": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ExecutionMetrics": {
      "type": "object",
      "required": [
        "execution_started_at",
        "execution_completed_at",
        "execution_duration_ms",
        "verification_duration_ms",
        "total_duration_ms",
        "timeout_triggered",
        "retries_attempted"
      ],
      "properties": {
        "execution_started_at": { "type": "string", "format": "date-time" },
        "execution_completed_at": { "type": "string", "format": "date-time" },
        "execution_duration_ms": { "type": "integer", "minimum": 0 },
        "verification_duration_ms": { "type": "integer", "minimum": 0 },
        "total_duration_ms": { "type": "integer", "minimum": 0 },
        "timeout_triggered": { "type": "boolean" },
        "retries_attempted": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "ReputationImpact": {
      "type": "object",
      "required": ["agent_id", "role_in_settlement", "outcome_for_agent", "success_rate_delta_bps", "dispute_filed"],
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^agent_[a-f0-9]{8}$"
        },
        "role_in_settlement": { "type": "string" },
        "outcome_for_agent": {
          "type": "string",
          "enum": ["positive", "negative", "neutral"]
        },
        "success_rate_delta_bps": { "type": "integer" },
        "quality_score_recorded_bps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "dispute_filed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "Signatures": {
      "type": "object",
      "required": ["settlement_engine", "payer", "payees"],
      "properties": {
        "settlement_engine": {
          "type": "string",
          "description": "Engine's signature attesting to the receipt."
        },
        "payer": {
          "type": "string",
          "description": "Payer's acknowledgment signature."
        },
        "payees": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["agent_id", "signature"],
            "properties": {
              "agent_id": {
                "type": "string",
                "pattern": "^agent_[a-f0-9]{8}$"
              },
              "signature": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
